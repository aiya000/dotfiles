{
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "agentPushNotifEnabled": true,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "filesystem": {
      "allowWrite": [
        "// `./bash-toys`などのsubmoduleでgit-commitを許可する",
        "~/.dotfiles/.git/",
        "// Windows filesystem (DrvFs) - bwrapがsandbox setup時に書き込みを要求するため",
        "/mnt/c/Users/aiya0/",
        "// `rm-dust`の退避先（ゴミ箱）",
        "~/.backup/dustbox/"
      ]
    }
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0
  },
  "permissions": {
    "allow": [
      "Bash(cp:*)",
      "Bash(ls:*)",
      "Bash(echo:*)",
      "Bash(touch:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git reflog:*)",
      "Bash(git commit:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue create:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(python3:*)",
      "Bash(notify:*)",
      "Read(~/.config/nvim)",
      "Skill(read-agents-md)",
      "Skill(suggest-alternative-commands)",
      "Skill(save-memory)",
      "Skill(git-commit)",
      "WebFetch(domain:api.github.com)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Read(.env.*)"
    ],
    "// `ask`: 通常モードでは確認プロンプト、bypassモードでは自動許可される（deny と違い bypass を素通りする）": "",
    "ask": [
      "Bash(git push:*)",
      "Bash(sudo:*)",
      "Bash(find:*)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "~/.dotfiles/.private/AI-MEMORY/"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "notify 'Claude Code' 'Claude Code stopped' ~/.dotfiles/bash-toys/assets/notification-1.mp3"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  }
}
