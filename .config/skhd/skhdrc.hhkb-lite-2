# Connect keymaps to default keyboard's actions {{{

# RHS (default keyboard's actions) defined by Raycast
# # TODO: Not working well
ctrl + cmd - a : skhd -k "cmd + 1"
ctrl + cmd - s : skhd -k "cmd + 2"
ctrl + cmd - d : skhd -k "cmd + 3"
ctrl + cmd - f : skhd -k "cmd + 4"
ctrl + cmd - g : skhd -k "cmd + 5"

# Esc -> '`'
escape : skhd -k "0x32"

# Shift + Esc -> ~
shift - escape : skhd -k "shift - 0x32"

# Ctrl + '[' -> Esc
ctrl - 0x1E : skhd -k "escape"

# }}}

# vim:foldmethod=marker
